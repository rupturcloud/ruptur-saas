# Ruptur SaaS - Variáveis de Ambiente
# Copie este arquivo para .env e preencha com seus valores

# Configurações GCP
GCP_PROJECT_ID=ruptur-jarvis-v1-68358
GCP_ZONE=southamerica-west1-a
GCP_INSTANCE_NAME=ruptur-shipyard-02
GCP_SSH_KEY_PATH=~/.ssh/google_compute_engine

# Configurações Docker
DOCKER_REGISTRY=gcr.io/ruptur-jarvis-v1-68358/saas
DOCKER_IMAGE_NAME=saas-saas-web

# Configurações da Aplicação
NODE_ENV=production
PORT=4173
HOST=0.0.0.0

# Domínios
DOMAIN_PRIMARY=app.ruptur.cloud
DOMAIN_SAAS=saas.ruptur.cloud
DOMAIN_ROOT=ruptur.cloud

# Integrações - UAZAPI
UAZAPI_BASE_URL=https://tiatendeai.uazapi.com
UAZAPI_TOKEN=SET_YOUR_UAZAPI_ADMIN_TOKEN
WARMUP_ADMIN_TOKEN=SET_YOUR_UAZAPI_ADMIN_TOKEN
WARMUP_SERVER_URL=https://tiatendeai.uazapi.com

# Integrações - Bubble
BUBBLE_API_URL=https://app.bubble.io/api/1.1/obj/
BUBBLE_API_KEY=SET_YOUR_BUBBLE_API_KEY
BUBBLE_APP_VERSION=live

# Integrações - Supabase
VITE_SUPABASE_URL=https://axrwlboyowoskdxeogba.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=PUBLIC_SUPABASE_KEY

# Integrações - Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Monitoramento e Logs
LOG_LEVEL=info
ENABLE_METRICS=true

# Segurança & Auth
JWT_SECRET=gere_uma_chave_forte_minimo_32_caracteres
GOOGLE_CLIENT_ID=seu_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=seu_client_secret
GOOGLE_REDIRECT_URI=https://app.ruptur.cloud/auth/google/callback
CORS_ORIGIN=https://app.ruptur.cloud
ENABLE_DEV_MODE=false
ENCRYPTION_KEY=sua_chave_de_encriptacao

# Notificações
SLACK_WEBHOOK=https://hooks.slack.com/services/...
DEPLOY_EMAIL=admin@ruptur.cloud

# Configurações de Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu_email@gmail.com
SMTP_PASS=sua_senha

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# File Upload
MAX_FILE_SIZE=10485760
UPLOAD_PATH=./uploads

# Analytics
GOOGLE_ANALYTICS_ID=GA_MEASUREMENT_ID
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
